# Environment configuration for AssistSupport
# Copy this file to .env and fill in the values as needed.

# Base URL for the AssistSupport search API backend
# ASSISTSUPPORT_SEARCH_API_BASE_URL=http://localhost:3000

# Path to the pdfium dynamic library (optional — needed for PDF support)
# PDFIUM_DYNAMIC_LIB_PATH=/usr/local/lib/libpdfium.dylib

# General Rust/logging settings
# RUST_BACKTRACE=1
# LOG_LEVEL=info
