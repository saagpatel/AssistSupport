pnpm check:workstation-preflight
node scripts/ci/require-tests-and-docs.mjs
pnpm check:workflow-drift
pnpm check:version-parity
pnpm ui:gate:static
pnpm test
pnpm test:coverage
bash scripts/ci/run-diff-coverage.sh
pnpm ui:gate:regression
pnpm git:guard:all
pnpm build:ui
pnpm perf:bundle
node scripts/perf/compare-metric.mjs .perf-baselines/bundle.json .perf-results/bundle.json totalBytes 0.10
pnpm perf:build
node scripts/perf/compare-metric.mjs .perf-baselines/build-time.json .perf-results/build-time.json buildMs 0.15
ASSET_MAX_BYTES=250000 bash scripts/perf/check-assets.sh
MEMORY_MAX_DELTA_MB=5 pnpm perf:memory
