{
  "name": "assistsupport",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:workstation-preflight": "node scripts/check_workstation_prereqs.mjs",
    "check:memorykernel-pin": "node scripts/validate_memorykernel_pin_sync.mjs",
    "check:memorykernel-governance": "node scripts/validate_memorykernel_governance_bundle.mjs",
    "check:memorykernel-handoff": "node scripts/validate_memorykernel_handoff_payload.mjs",
    "check:memorykernel-handoff:service-v3-candidate": "ASSISTSUPPORT_REQUIRE_HANDOFF_PAYLOAD=1 ASSISTSUPPORT_HANDOFF_REQUIRE_PIN_MATCH=0 MEMORYKERNEL_EXPECTED_SERVICE_CONTRACT_VERSION=service.v3 node scripts/validate_memorykernel_handoff_payload.mjs",
    "check:memorykernel-boundary": "node scripts/validate_memorykernel_boundary.mjs",
    "check:memorykernel-cutover-policy": "node scripts/validate_memorykernel_cutover_policy.mjs",
    "check:rollback-readiness": "node scripts/validate_rollback_readiness.mjs",
    "generate:llm-golden-set": "node scripts/generate_llm_golden_set_latest.mjs",
    "check:llm-golden-set": "pnpm run generate:llm-golden-set && node scripts/validate_llm_golden_set.mjs",
    "check:phase6-ops-hardening": "node scripts/run_phase6_ops_hardening.mjs",
    "test:security-regression": "cd src-tauri && cargo test security -- --nocapture && cargo test ssrf_dns_rebinding -- --nocapture && cargo test filter_injection -- --nocapture && cargo test path_validation -- --nocapture",
    "test:memorykernel-governance-negative": "node scripts/test_memorykernel_governance_negative.mjs",
    "test:memorykernel-contract": "pnpm run check:memorykernel-pin && pnpm run check:memorykernel-governance && pnpm run check:memorykernel-boundary && pnpm run check:memorykernel-cutover-policy && vitest run src/hooks/useInitialize.test.ts src/hooks/useMemoryKernelEnrichment.test.ts && (cd src-tauri && cargo test memory_kernel -- --nocapture) && node scripts/generate_memorykernel_contract_evidence.mjs",
    "test:memorykernel-phase3-dry-run": "ASSISTSUPPORT_REQUIRE_HANDOFF_PAYLOAD=1 pnpm run check:memorykernel-handoff && pnpm run test:memorykernel-contract",
    "test:memorykernel-cutover-dry-run": "pnpm run check:memorykernel-handoff:service-v3-candidate && pnpm run check:memorykernel-pin && pnpm run test:memorykernel-contract && pnpm run test:ci",
    "test:e2e:smoke": "playwright test --config=playwright.config.ts --grep @smoke",
    "test:e2e:ops": "playwright test --config=playwright.config.ts e2e/ops.spec.ts",
    "test:e2e:revamp": "playwright test --config=playwright.config.ts e2e/revamp-queue-workflow.spec.ts",
    "test:revamp-queue-rehearsal": "bash scripts/run_revamp_queue_rehearsal.sh",
    "test:ci": "vitest run && cd src-tauri && cargo test",
    "check:revamp-style": "bash scripts/check_revamp_style.sh",
    "check:monorepo-readiness": "bash scripts/run_monorepo_readiness.sh quick",
    "check:monorepo-readiness:full": "bash scripts/run_monorepo_readiness.sh full",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^27.4.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
